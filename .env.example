# ── LLM: Azure OpenAI (primary) ───────────────────────────────────────────────
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# ── LLM: Generic OpenAI-compatible fallback (e.g. Ollama, Groq, Together) ─────
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama

# ── Image sources (true = enabled) ────────────────────────────────────────────
IMAGE_SOURCE_WIKIMEDIA=true
IMAGE_SOURCE_OPENVERSE=true
IMAGE_SOURCE_PICSUM=true          # always-available placeholder fallback

# ── Icons ─────────────────────────────────────────────────────────────────────
# ICON_LOCAL_DIR=/path/to/my/icons   # optional extra icon folder (highest priority)

# ── Defaults ──────────────────────────────────────────────────────────────────
DEFAULT_OUTPUT_DIR=./output
DEFAULT_SLIDE_COUNT=10
DEFAULT_THEME=dark                   # dark | corporate | minimalist
